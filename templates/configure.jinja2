<!DOCTYPE html>
<html lang="ru">
<head>
    <title>Stremak</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
        * { box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            max-width: 500px;
            margin: 40px auto;
            padding: 20px;
            background: #1a1a2e;
            color: #eee;
        }
        h1 { color: #7b2cbf; margin-bottom: 24px; font-size: 1.5em; }
        .card {
            background: #252542;
            border-radius: 12px;
            padding: 24px;
            margin-bottom: 16px;
        }
        .service-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 16px;
        }
        .service-header h3 { margin: 0; flex: 1; }
        .status-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #666;
        }
        .status-dot.connected { background: #4ade80; }
        input[type="text"] {
            width: 100%;
            padding: 12px;
            border: 1px solid #444;
            border-radius: 8px;
            background: #1a1a2e;
            color: #eee;
            font-size: 16px;
        }
        select {
            width: 100%;
            padding: 12px;
            border: 1px solid #444;
            border-radius: 8px;
            background: #1a1a2e;
            color: #eee;
            font-size: 16px;
        }
        input[type="text"]:disabled { opacity: 0.6; }
        button, .btn {
            display: inline-block;
            padding: 12px 24px;
            background: #7b2cbf;
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 16px;
            text-decoration: none;
            text-align: center;
        }
        button:hover, .btn:hover { background: #9d4edd; }
        .btn-secondary { background: #444; }
        .btn-secondary:hover { background: #555; }
        .btn-small { padding: 8px 16px; font-size: 14px; }
        .btn-text {
            background: none;
            padding: 8px;
            color: #888;
            font-size: 14px;
            visibility: hidden;
        }
        .btn-text.visible { visibility: visible; }
        .btn-text:hover { background: none; color: #aaa; }
        .btn-copy {
            transition: background 0.15s, color 0.15s;
        }
        .btn-copy.copied {
            animation: flash-green 0.3s;
        }
        @keyframes flash-green {
            0% { background: #2d8a4e; }
            100% { background: #444; }
        }
        .hint {
            font-size: 14px;
            color: #888;
        }
        .hint a {
            color: #7b2cbf;
            text-decoration: none;
        }
        .hint a:hover {
            color: #9d4edd;
        }
        .input-error {
            color: #ff6b6b;
            margin-top: 12px;
        }
        .code {
            font-size: 32px;
            font-weight: bold;
            letter-spacing: 4px;
            color: #7b2cbf;
            text-align: center;
            padding: 16px;
        }
        .steps { color: #aaa; line-height: 1.8; }
        .steps a { color: #7b2cbf; }
        .hidden { display: none !important; }
        .install-url {
            word-break: break-all;
            background: #1a1a2e;
            padding: 12px;
            border-radius: 8px;
            font-family: monospace;
            font-size: 12px;
            margin-bottom: 12px;
        }
        .flex { display: flex; gap: 8px; }
        .flex-1 { flex: 1; }
        .user-info {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px;
            background: #1a1a2e;
            border-radius: 8px;
            margin-bottom: 16px;
        }
        .user-info .avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: #444;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }
        .user-info .avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .user-info .avatar svg { width: 24px; height: 24px; fill: #888; }
        .user-info .details { flex: 1; }
        .user-info .login { font-weight: bold; }
        .user-info .meta { font-size: 12px; color: #888; }
        .poll-status {
            text-align: center;
            color: #888;
            font-size: 14px;
            margin-top: 12px;
        }
        .poll-status .spinner {
            display: inline-block;
            width: 12px;
            height: 12px;
            border: 2px solid #444;
            border-top-color: #7b2cbf;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin-right: 8px;
        }
        .input-row {
            display: flex;
            gap: 8px;
            margin-bottom: 16px;
        }
        .input-row input { flex: 1; }
        .divider {
            display: flex;
            align-items: center;
            gap: 12px;
            color: #666;
            font-size: 14px;
            margin-bottom: 16px;
        }
        .divider::before, .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #444;
        }
        .priority-list {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .priority-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 10px 12px;
            border: 1px solid #444;
            border-radius: 8px;
            background: #1a1a2e;
            transition: border-color 0.15s, background 0.15s, transform 0.15s;
        }
        .priority-item.dragging {
            opacity: 0.65;
            transform: scale(0.99);
        }
        .priority-item.drag-over {
            border-color: #7b2cbf;
            background: #21213a;
        }
        .priority-label {
            display: flex;
            align-items: center;
            gap: 12px;
            min-width: 0;
        }
        .priority-code {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 42px;
            padding: 4px 8px;
            border-radius: 999px;
            background: #35355c;
            color: #d7c7ff;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 0.08em;
        }
        .priority-name {
            font-weight: 600;
        }
        .priority-handle {
            color: #888;
            cursor: grab;
            font-size: 18px;
            user-select: none;
        }
        .priority-item.dragging .priority-handle {
            cursor: grabbing;
        }
        .priority-buttons {
            display: flex;
            gap: 6px;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
    </style>
</head>
<body>
    <h1>Stremak</h1>

    <script>
        const baseUrl = window.location.origin;
        const parsingSpecs = {{ parsing_specs|tojson }};
        const audioLanguages = parsingSpecs.attrs.lang.ui_values;
        const supportedAudioLangs = Object.keys(audioLanguages);
        const initialLanguageScores = parsingSpecs.attrs.lang.default_scores;
        const DEFAULT_AVATAR_SVG = '<svg viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>';
        let draggedAudioLang = null;
        const currentLanguageScores = {
            ...initialLanguageScores,
            ...Object.fromEntries(
                Object.entries({{ config.get('parsing', {}).get('specs', {}).get('attrs', {}).get('lang', {}).get('values', {})|tojson }})
                    .map(([lang, override]) => [lang, override.score])
                    .filter(([, score]) => score !== undefined && score !== null),
            ),
        };
        let audioPriority = deriveAudioPriority(currentLanguageScores);

        const services = {
            {% for service in services %}
            {{ service.slug }}: { ...{{ config.get('streaming', {}).get(service.slug, {})|tojson }}, userInfo: null, verified: false, checkRequestId: 0 },
            {% endfor %}
        };

        const metadata = {
            {% for meta in metadata %}
            {{ meta.slug }}: {{ config.get('metadata', {}).get(meta.slug)|tojson|default('null') }},
            {% endfor %}
        };
        for (const [key, value] of Object.entries(metadata)) {
            if (value) {
                metadata[key] = { ...value, verified: false };
            }
        }

        function deriveAudioPriority(languageScores) {
            if (!languageScores || typeof languageScores !== 'object') {
                return [...supportedAudioLangs];
            }

            const ordered = [...supportedAudioLangs].sort((left, right) => {
                const diff = Number(languageScores[right] ?? 0) - Number(languageScores[left] ?? 0);
                if (diff !== 0) return diff;
                return supportedAudioLangs.indexOf(left) - supportedAudioLangs.indexOf(right);
            });

            return ordered;
        }

        function buildLanguageScores() {
            const scores = {};
            const orderedScores = Object.values(initialLanguageScores).sort((left, right) => right - left);
            audioPriority.forEach((lang, index) => {
                scores[lang] = orderedScores[index] ?? 0;
            });
            return scores;
        }

        function updateInstallSection() {
            const hasService = Object.values(services).some(s => s.verified);
            const hasMetadata = Object.values(metadata).some(m => m?.verified);

            if (!hasService || !hasMetadata) {
                document.getElementById('install-section').classList.add('hidden');
                history.replaceState(null, '', '/configure');
                return;
            }

            document.getElementById('install-section').classList.remove('hidden');

            const languageScores = buildLanguageScores();
            const config = { streaming: {}, metadata: {} };
            const languageOverrides = Object.fromEntries(
                Object.entries(languageScores)
                    .filter(([lang, score]) => score !== initialLanguageScores[lang])
                    .map(([lang, score]) => [lang, { score }]),
            );
            if (Object.keys(languageOverrides).length > 0) {
                config.parsing = {
                    specs: {
                        attrs: {
                            lang: {
                                values: languageOverrides,
                            },
                        },
                    },
                };
            }
            for (const [key, svc] of Object.entries(services)) {
                const { userInfo, verified, checkRequestId, ...svcConfig } = svc;
                if (verified) config.streaming[key] = svcConfig;
            }
            for (const [key, meta] of Object.entries(metadata)) {
                if (meta?.verified) {
                    const { verified, ...metaConfig } = meta;
                    config.metadata[key] = metaConfig;
                }
            }

            const configStr = btoa(JSON.stringify(config)).replace(/=+$/, '');
            const manifestUrl = `${baseUrl}/${configStr}/manifest.json`;
            const stremioUrl = 'stremio://' + manifestUrl.replace(/^https?:\/\//, '');

            document.getElementById('install-url').textContent = manifestUrl;
            document.getElementById('install-link').href = stremioUrl;
            history.replaceState(null, '', `/${configStr}/configure`);
        }

        function handleAvatarError(img) {
            img.parentElement.innerHTML = DEFAULT_AVATAR_SVG;
        }

        function copyUrl(e) {
            const btn = e.target;
            navigator.clipboard.writeText(document.getElementById('install-url').textContent);
            btn.classList.remove('copied');
            btn.offsetHeight; // force reflow to restart animation
            btn.classList.add('copied');
        }

        function moveAudioPriority(index, direction) {
            const next = index + direction;
            if (next < 0 || next >= audioPriority.length) return;
            [audioPriority[index], audioPriority[next]] = [audioPriority[next], audioPriority[index]];
            renderAudioPriority();
            updateInstallSection();
        }

        function moveAudioPriorityTo(fromIndex, toIndex) {
            if (fromIndex < 0 || toIndex < 0 || fromIndex === toIndex) return;
            const [lang] = audioPriority.splice(fromIndex, 1);
            audioPriority.splice(toIndex, 0, lang);
            renderAudioPriority();
            updateInstallSection();
        }

        function renderAudioPriority() {
            const root = document.getElementById('audio-priority-list');
            if (!root) return;
            root.innerHTML = '';

            audioPriority.forEach((lang, index) => {
                const label = audioLanguages[lang] || { code: lang.toUpperCase(), label: lang.toUpperCase() };
                const item = document.createElement('div');
                item.className = 'priority-item';
                item.draggable = true;
                item.innerHTML = `
                    <div class="priority-label">
                        <span class="priority-handle" title="Drag to reorder">≡</span>
                        <span class="priority-code">${label.code}</span>
                        <span class="priority-name">${label.label}</span>
                    </div>
                    <div class="priority-buttons">
                        <button type="button" class="btn-secondary btn-small" ${index === 0 ? 'disabled' : ''}>↑</button>
                        <button type="button" class="btn-secondary btn-small" ${index === audioPriority.length - 1 ? 'disabled' : ''}>↓</button>
                    </div>
                `;
                item.addEventListener('dragstart', () => {
                    draggedAudioLang = lang;
                    item.classList.add('dragging');
                });
                item.addEventListener('dragend', () => {
                    draggedAudioLang = null;
                    item.classList.remove('dragging');
                    root.querySelectorAll('.priority-item').forEach(node => node.classList.remove('drag-over'));
                });
                item.addEventListener('dragover', event => {
                    if (draggedAudioLang === null || draggedAudioLang === lang) return;
                    event.preventDefault();
                    item.classList.add('drag-over');
                });
                item.addEventListener('dragleave', () => {
                    item.classList.remove('drag-over');
                });
                item.addEventListener('drop', event => {
                    if (draggedAudioLang === null) return;
                    event.preventDefault();
                    item.classList.remove('drag-over');
                    moveAudioPriorityTo(audioPriority.indexOf(draggedAudioLang), index);
                });
                const buttons = item.querySelectorAll('button');
                buttons[0].addEventListener('click', () => moveAudioPriority(index, -1));
                buttons[1].addEventListener('click', () => moveAudioPriority(index, 1));
                root.appendChild(item);
            });
        }
    </script>

    <div class="card">
        <div class="service-header">
            <h3>Приоритет аудио</h3>
        </div>
        <div class="hint">Перетаскивайте языки, чтобы менять их порядок, или используйте кнопки со стрелками.</div>
        <div id="audio-priority-list" class="priority-list" style="margin-top: 12px;"></div>
    </div>

    {% for service in services %}
        {% include service.template %}
    {% endfor %}

    {% for meta in metadata %}
        {% include meta.template %}
    {% endfor %}

    <div class="card hidden" id="install-section">
        <div class="install-url" id="install-url"></div>
        <div class="flex">
            <a id="install-link" class="btn flex-1" href="#">Установить в Stremio</a>
            <button class="btn-secondary btn-copy" onclick="copyUrl(event)">Копировать</button>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            renderAudioPriority();
            {% for service in services %}
            if (services.{{ service.slug }}.token) {
                window['{{ service.slug }}CheckToken']?.();
            }
            {% endfor %}
            updateInstallSection();
        });
    </script>
</body>
</html>
