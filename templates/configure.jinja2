<!DOCTYPE html>
<html lang="ru">
<head>
    <title>Stremak</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
        * { box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            max-width: 500px;
            margin: 40px auto;
            padding: 20px;
            background: #1a1a2e;
            color: #eee;
        }
        h1 { color: #7b2cbf; margin-bottom: 24px; font-size: 1.5em; }
        .card {
            background: #252542;
            border-radius: 12px;
            padding: 24px;
            margin-bottom: 16px;
        }
        .service-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 16px;
        }
        .service-header h3 { margin: 0; flex: 1; }
        .status-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #666;
        }
        .status-dot.connected { background: #4ade80; }
        input[type="text"] {
            width: 100%;
            padding: 12px;
            border: 1px solid #444;
            border-radius: 8px;
            background: #1a1a2e;
            color: #eee;
            font-size: 16px;
        }
        select {
            width: 100%;
            padding: 12px;
            border: 1px solid #444;
            border-radius: 8px;
            background: #1a1a2e;
            color: #eee;
            font-size: 16px;
        }
        input[type="text"]:disabled { opacity: 0.6; }
        button, .btn {
            display: inline-block;
            padding: 12px 24px;
            background: #7b2cbf;
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 16px;
            text-decoration: none;
            text-align: center;
        }
        button:hover, .btn:hover { background: #9d4edd; }
        .btn-secondary { background: #444; }
        .btn-secondary:hover { background: #555; }
        .btn-small { padding: 8px 16px; font-size: 14px; }
        .btn-text {
            background: none;
            padding: 8px;
            color: #888;
            font-size: 14px;
            visibility: hidden;
        }
        .btn-text.visible { visibility: visible; }
        .btn-text:hover { background: none; color: #aaa; }
        .btn-copy {
            transition: background 0.15s, color 0.15s;
        }
        .btn-copy.copied {
            animation: flash-green 0.3s;
        }
        @keyframes flash-green {
            0% { background: #2d8a4e; }
            100% { background: #444; }
        }
        .hint {
            font-size: 14px;
            color: #888;
        }
        .hint a {
            color: #7b2cbf;
            text-decoration: none;
        }
        .hint a:hover {
            color: #9d4edd;
        }
        .input-error {
            color: #ff6b6b;
            margin-top: 12px;
        }
        .code {
            font-size: 32px;
            font-weight: bold;
            letter-spacing: 4px;
            color: #7b2cbf;
            text-align: center;
            padding: 16px;
        }
        .steps { color: #aaa; line-height: 1.8; }
        .steps a { color: #7b2cbf; }
        .hidden { display: none !important; }
        .install-url {
            word-break: break-all;
            background: #1a1a2e;
            padding: 12px;
            border-radius: 8px;
            font-family: monospace;
            font-size: 12px;
            margin-bottom: 12px;
        }
        .flex { display: flex; gap: 8px; }
        .flex-1 { flex: 1; }
        .user-info {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px;
            background: #1a1a2e;
            border-radius: 8px;
            margin-bottom: 16px;
        }
        .user-info .avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: #444;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }
        .user-info .avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .user-info .avatar svg { width: 24px; height: 24px; fill: #888; }
        .user-info .details { flex: 1; }
        .user-info .login { font-weight: bold; }
        .user-info .meta { font-size: 12px; color: #888; }
        .poll-status {
            text-align: center;
            color: #888;
            font-size: 14px;
            margin-top: 12px;
        }
        .poll-status .spinner {
            display: inline-block;
            width: 12px;
            height: 12px;
            border: 2px solid #444;
            border-top-color: #7b2cbf;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin-right: 8px;
        }
        .input-row {
            display: flex;
            gap: 8px;
            margin-bottom: 16px;
        }
        .input-row input { flex: 1; }
        .divider {
            display: flex;
            align-items: center;
            gap: 12px;
            color: #666;
            font-size: 14px;
            margin-bottom: 16px;
        }
        .divider::before, .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #444;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
    </style>
</head>
<body>
    <h1>Stremak</h1>

    <script>
        const baseUrl = window.location.origin;
        const defaultLocale = {{ default_locale|tojson }};
        const DEFAULT_AVATAR_SVG = '<svg viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>';
        let locale = {{ config.get('locale', default_locale)|tojson }};

        const services = {
            {% for service in services %}
            {{ service.slug }}: { ...{{ config.get('streaming', {}).get(service.slug, {})|tojson }}, userInfo: null },
            {% endfor %}
        };

        const metadata = {
            {% for meta in metadata %}
            {{ meta.slug }}: {{ config.get('metadata', {}).get(meta.slug)|tojson|default('null') }},
            {% endfor %}
        };

        function updateInstallSection() {
            const hasService = Object.values(services).some(s => s.token);
            const hasMetadata = Object.values(metadata).some(m => m);

            if (!hasService || !hasMetadata) {
                document.getElementById('install-section').classList.add('hidden');
                history.replaceState(null, '', '/configure');
                return;
            }

            document.getElementById('install-section').classList.remove('hidden');

            const config = { locale, streaming: {}, metadata: {} };
            for (const [key, svc] of Object.entries(services)) {
                const {userInfo, ...svcConfig} = svc;
                if (svc.token) config.streaming[key] = svcConfig;
            }
            for (const [key, meta] of Object.entries(metadata)) {
                if (meta) config.metadata[key] = meta;
            }

            const configStr = btoa(JSON.stringify(config)).replace(/=+$/, '');
            const manifestUrl = `${baseUrl}/${configStr}/manifest.json`;
            const stremioUrl = 'stremio://' + manifestUrl.replace(/^https?:\/\//, '');

            document.getElementById('install-url').textContent = manifestUrl;
            document.getElementById('install-link').href = stremioUrl;
            history.replaceState(null, '', `/${configStr}/configure`);
        }

        function handleAvatarError(img) {
            img.parentElement.innerHTML = DEFAULT_AVATAR_SVG;
        }

        function copyUrl(e) {
            const btn = e.target;
            navigator.clipboard.writeText(document.getElementById('install-url').textContent);
            btn.classList.remove('copied');
            btn.offsetHeight; // force reflow to restart animation
            btn.classList.add('copied');
        }

        function updateLocale(value) {
            locale = value || defaultLocale;
            updateInstallSection();
        }
    </script>

    <div class="card">
        <div class="service-header">
            <h3>Language</h3>
        </div>
        <select id="locale-select" onchange="updateLocale(this.value)">
            <option value="ru">Русский</option>
            <option value="en">English</option>
        </select>
    </div>

    {% for service in services %}
        {% include service.template %}
    {% endfor %}

    {% for meta in metadata %}
        {% include meta.template %}
    {% endfor %}

    <div class="card hidden" id="install-section">
        <div class="install-url" id="install-url"></div>
        <div class="flex">
            <a id="install-link" class="btn flex-1" href="#">Установить в Stremio</a>
            <button class="btn-secondary btn-copy" onclick="copyUrl(event)">Копировать</button>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            document.getElementById('locale-select').value = locale;
            {% for service in services %}
            if (services.{{ service.slug }}.token) {
                window['{{ service.slug }}CheckToken']?.();
            }
            {% endfor %}
            updateInstallSection();
        });
    </script>
</body>
</html>
